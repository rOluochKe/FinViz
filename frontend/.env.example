# API Configuration
REACT_APP_API_URL=http://localhost:5000/api

# Feature Flags
REACT_APP_ENABLE_DARK_MODE=false
REACT_APP_ENABLE_NOTIFICATIONS=true

# Pagination
REACT_APP_DEFAULT_PAGE_SIZE=20
REACT_APP_MAX_PAGE_SIZE=100

# Date Format
REACT_APP_DATE_FORMAT=YYYY-MM-DD
REACT_APP_TIME_FORMAT=HH:mm:ss
REACT_APP_DATETIME_FORMAT=YYYY-MM-DD HH:mm:ss

# Currency
REACT_APP_DEFAULT_CURRENCY=USD
REACT_APP_CURRENCY_SYMBOL=$

# Cache
REACT_APP_CACHE_TIMEOUT=300000