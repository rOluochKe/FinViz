[flake8]
max-line-length = 100
extend-ignore = 
    F403,
    F405
per-file-ignores = 
    app/utils/__init__.py: F403,F405
    app/models/__init__.py: F403,F405
    app/routes/__init__.py: F403,F405
    app/services/__init__.py: F403,F405
    app/middleware/__init__.py: F403,F405
exclude = 
    .git,
    __pycache__,
    build,
    dist,
    migrations,
    venv,
    .venv,
    env